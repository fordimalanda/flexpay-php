{
    "name": "devscast/flexpay",
    "description": "FlexPay API PHP Client",
    "keywords": [
        "flexpay",
        "mobile money",
        "payment gateway",
        "api"
    ],
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Devscast\\Flexpay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Devscast\\Flexpay\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "bernard-ng",
            "email": "bernard@devscast.tech"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.4",
        "symfony/http-client": "^7.0|^8.0",
        "webmozart/assert": "^1.11",
        "symfony/serializer": "^7.0|^8.0",
        "symfony/property-access": "^7.0|^8.0"
    },
    "require-dev": {
        "symfony/var-dumper": "^7.0|^8.0",
        "rector/rector": "^2.3",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^13.0",
        "symplify/easy-coding-standard": "^13.0"
    }
}
